{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "includeFiles": "api/**"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/[...path].js" },
    { "src": "/admin", "dest": "/admin/index.html" },
    { "src": "/admin/(.*)", "dest": "/admin/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "cleanUrls": true
}
